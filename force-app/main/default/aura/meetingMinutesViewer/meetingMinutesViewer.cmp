<aura:component implements="flexipage:availableForRecordHome,force:hasRecordId" access="global">
    
    <aura:attribute name="record" type="Object"/>
    <aura:attribute name="temas" type="List"/>
    <aura:attribute name="conteudo" type="String"/>
    <aura:attribute name="meetingTitle" type="String"/>
    <aura:attribute name="meetingDate" type="String"/>

    <force:recordData aura:id="recordLoader"
        recordId="{!v.recordId}"
        targetFields="{!v.record}"
        fields="Name,Conteudo_Ata__c,Data_Reuniao__c"
        recordUpdated="{!c.onRecordLoaded}"/>

    <lightning:card>
        <aura:set attribute="title">
            <lightning:icon iconName="standard:note" size="small"/> &nbsp;
            {!v.meetingTitle}
        </aura:set>
        <aura:set attribute="actions">
            <lightning:button label="Baixar TXT" iconName="utility:download" onclick="{!c.downloadTXT}"/>
        </aura:set>

        <div class="slds-p-around_medium">

            <!-- Header -->
            <div class="header-box">
                <p class="meeting-title">{!v.meetingTitle}</p>
                <p class="meeting-info">📅 {!v.meetingDate} &nbsp;|&nbsp; 🤖 Gerado via Gemini AI</p>
            </div>

            <!-- Temas -->
            <aura:iteration items="{!v.temas}" var="tema">
                <div class="tema-block">
                    <div class="tema-header">
                        <lightning:icon iconName="utility:topic" size="x-small"/>
                        &nbsp; {!tema.nome}
                    </div>

                    <!-- Contexto -->
                    <aura:if isTrue="{!tema.contexto}">
                        <div class="section-block">
                            <p class="section-title">📋 Contexto</p>
                            <p class="section-content">{!tema.contexto}</p>
                        </div>
                    </aura:if>

                    <!-- Gaps -->
                    <aura:if isTrue="{!tema.gaps.length}">
                        <div class="section-block gaps-block">
                            <p class="section-title">⚠️ Gaps Identificados</p>
                            <aura:iteration items="{!tema.gaps}" var="gap">
                                <div class="gap-item">• {!gap}</div>
                            </aura:iteration>
                        </div>
                    </aura:if>

                    <!-- Próximos Passos -->
                    <aura:if isTrue="{!tema.proximosPassos.length}">
                        <div class="section-block">
                            <p class="section-title">✅ Próximos Passos</p>
                            <table class="passos-table">
                                <thead>
                                    <tr>
                                        <th>Ação</th>
                                        <th>Responsável</th>
                                        <th>Prazo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration items="{!tema.proximosPassos}" var="passo">
                                        <tr>
                                            <td>{!passo.acao}</td>
                                            <td>{!passo.responsavel}</td>
                                            <td>{!passo.prazo}</td>
                                        </tr>
                                    </aura:iteration>
                                </tbody>
                            </table>
                        </div>
                    </aura:if>

                    <!-- User Stories -->
                    <aura:if isTrue="{!tema.userStories.length}">
                        <div class="section-block us-block">
                            <p class="section-title">📌 User Stories</p>
                            <aura:iteration items="{!tema.userStories}" var="us">
                                <div class="us-card">
                                    <div class="us-header">
                                        <span class="us-id">{!us.id}</span>
                                        <span class="us-titulo">{!us.titulo}</span>
                                        <span class="{!us.prioridadeClass}">{!us.prioridade}</span>
                                    </div>
                                    <p class="us-desc">{!us.descricao}</p>
                                    <aura:if isTrue="{!us.gherkin}">
                                        <div class="gherkin-block">
                                            <pre class="gherkin-text">{!us.gherkin}</pre>
                                        </div>
                                    </aura:if>
                                </div>
                            </aura:iteration>
                        </div>
                    </aura:if>

                </div>
            </aura:iteration>

            <!-- Fallback raw -->
            <aura:if isTrue="{!empty(v.temas)}">
                <pre class="raw-content">{!v.conteudo}</pre>
            </aura:if>

        </div>
    </lightning:card>
</aura:component>